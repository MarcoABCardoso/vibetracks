{
  "name": "exploration",
  "extends": "../soundtrack.json",
  "_comment": "Calm, spacious overworld music — long and evolving. A-section uses the first 3 notes of the theme as a sparse callback over minor pads; B-section brightens toward C major and answers with the theme's descending TAIL, so a long loop keeps unfolding instead of repeating.",
  "bpm": 100,
  "time_signature": [4, 4],

  "palette": {
    "pluck": { "gain": 0.45, "filter": 3800, "reverb": 0.3 },
    "drums": { "gain": 0.55 }
  },

  "sections": [
    {
      "name": "intro",
      "bars": 4,
      "parts": {
        "pad": { "instrument": "pad", "chords": ["Am", "C", "F", "G"], "chord_beats": 4, "gain": 0.5 }
      }
    },
    {
      "name": "A",
      "bars": 8,
      "loop": true,
      "parts": {
        "pad":   { "instrument": "pad", "chords": ["Am", "C", "F", "G", "Dm", "Am", "Em", "G"], "chord_beats": 4 },
        "pluck": { "instrument": "pluck", "motif": "main_theme", "slice": [0, 3], "pan": -0.15, "gain": 0.4 },
        "bass":  { "instrument": "bass",
                   "notes": [["A2", 4], ["C2", 4], ["F2", 4], ["G2", 4],
                             ["D2", 4], ["A2", 4], ["E2", 4], ["G2", 4]] },
        "arp":   { "instrument": "arp", "repeat": 8, "pan": 0.3, "gain": 0.28,
                   "notes": [["E5", 1], ["A5", 1], ["C6", 1], ["A5", 1]] },
        "drums": { "instrument": "drums",
                   "drums": { "kick": "x.......", "hat": "..x...x." } }
      }
    },
    {
      "name": "B",
      "bars": 8,
      "loop": true,
      "_comment": "Brighter relative-major drift; the theme's tail (notes 3-6) answers, panned opposite the A-section callback.",
      "parts": {
        "pad":   { "instrument": "pad", "chords": ["C", "G", "Am", "F", "Dm", "G", "C", "C"], "chord_beats": 4 },
        "pluck": { "instrument": "pluck", "motif": "main_theme", "slice": [3, 7], "pan": 0.2, "gain": 0.4 },
        "bass":  { "instrument": "bass",
                   "notes": [["C2", 4], ["G2", 4], ["A2", 4], ["F2", 4],
                             ["D2", 4], ["G2", 4], ["C2", 4], ["C2", 4]] },
        "arp":   { "instrument": "arp", "repeat": 8, "pan": -0.3, "gain": 0.28,
                   "notes": [["G5", 1], ["C6", 1], ["E6", 1], ["C6", 1]] },
        "drums": { "instrument": "drums",
                   "drums": { "kick": "x.......", "hat": "..x.x.x." } }
      }
    }
  ]
