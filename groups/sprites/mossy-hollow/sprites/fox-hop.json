{
  "name": "fox-hop",
  "extends": "../artbook.json",
  "_comment": "A 4-frame hop: the same 'fox' motif re-posed by sliding it up and down the canvas (no separate limb rig needed for a simple bounce) — crouch, rise, peak, land — with a small dust puff on the landing frame. The animation analogue of restating a motif with only its timing changed.",
  "size": [14, 19],
  "frames": [
    {
      "name": "crouch",
      "layers": [
        { "name": "body", "shape": "fox", "offset": [0, 5] },
        { "name": "charm", "shape": "leaf", "offset": [5, 13] }
      ]
    },
    {
      "name": "rise",
      "layers": [
        { "name": "body", "shape": "fox", "offset": [0, 1] },
        { "name": "charm", "shape": "leaf", "offset": [5, 9] }
      ]
    },
    {
      "name": "peak",
      "layers": [
        { "name": "body", "shape": "fox", "offset": [0, 0] },
        { "name": "charm", "shape": "leaf", "offset": [5, 8] }
      ]
    },
    {
      "name": "land",
      "hold": 2,
      "layers": [
        { "name": "body", "shape": "fox", "offset": [0, 4] },
        { "name": "charm", "shape": "leaf", "offset": [5, 12] },
        { "name": "dust_l", "ellipse": { "at": [1, 16], "size": [5, 3], "color": "fur_sh" } },
        { "name": "dust_r", "ellipse": { "at": [8, 16], "size": [5, 3], "color": "fur_sh" } }
      ]
    }
  ]
}
