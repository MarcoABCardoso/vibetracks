{
  "name": "boss",
  "extends": "../soundtrack.json",
  "_comment": "Dark boss fight led by the 'danger' motif. A-section echoes the theme head an octave down; the B-section twists the same head with melodic INVERSION (its contour mirrored) — the familiar hook turned chromatic and wrong-sounding, then a tension build.",
  "bpm": 150,
  "key": "A harmonic_minor",
  "time_signature": [4, 4],

  "palette": {
    "lead": { "filter": 4200, "gain": 0.7, "reverb": 0.25 },
    "pad":  { "filter": 2200, "gain": 0.4 },
    "bass": { "filter": 1500, "gain": 1.0 }
  },

  "sections": [
    {
      "name": "intro",
      "bars": 2,
      "parts": {
        "pad":   { "instrument": "pad", "chords": ["Am", "E"], "chord_beats": 4, "gain": 0.45 },
        "pluck": { "instrument": "pluck", "motif": "danger", "repeat": 2, "gain": 0.6 }
      }
    },
    {
      "name": "A",
      "bars": 4,
      "loop": true,
      "parts": {
        "lead":  { "instrument": "lead", "motif": "main_theme", "slice": [0, 4], "transpose": -12, "gain": 0.7 },
        "pluck": { "instrument": "pluck", "motif": "danger", "repeat": 4, "pan": -0.25, "gain": 0.6 },
        "bass":  { "instrument": "bass",
                   "notes": [["A1", 0.5], ["A1", 0.5], ["A2", 0.5], ["A1", 0.5],
                             ["A1", 0.5], ["A1", 0.5], ["A2", 0.5], ["A1", 0.5],
                             ["F1", 0.5], ["F1", 0.5], ["F2", 0.5], ["F1", 0.5],
                             ["F1", 0.5], ["F1", 0.5], ["F2", 0.5], ["F1", 0.5],
                             ["D2", 0.5], ["D2", 0.5], ["D3", 0.5], ["D2", 0.5],
                             ["D2", 0.5], ["D2", 0.5], ["D3", 0.5], ["D2", 0.5],
                             ["E2", 0.5], ["E2", 0.5], ["E3", 0.5], ["E2", 0.5],
                             ["E2", 0.5], ["E2", 0.5], ["E3", 0.5], ["E2", 0.5]] },
        "pad":   { "instrument": "pad", "chords": ["Am", "F", "Dm", "E"], "chord_beats": 4 },
