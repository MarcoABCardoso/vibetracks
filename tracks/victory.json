                             ["E5", 0.5], ["F5", 0.5], ["G5", 0.5], ["A5", 0.5],
                             ["B5", 0.5], ["C6", 0.5], ["D6", 0.5], ["E6", 0.5],
                             ["A5", 0.5], ["C6", 0.5], ["E6", 0.5], ["A6", 0.5],
