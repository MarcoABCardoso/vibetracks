        "lead":  { "instrument": "lead", "motif": "main_theme", "slice": [0, 4], "invert": true, "transpose": -5, "stretch": 2.0, "gain": 0.72 },
        "pluck":    { "instrument": "pluck", "motif": "danger", "repeat": 4, "pan": -0.3, "gain": 0.6 },
        "pluck_hi": { "instrument": "pluck", "motif": "danger", "transpose": 12, "repeat": 4, "pan": 0.3, "gain": 0.38 },
        "bass":  { "instrument": "bass",
