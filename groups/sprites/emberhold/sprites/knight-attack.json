{
  "name": "knight-attack",
  "extends": "../artbook.json",
  "_comment": "7-frame overhead sword slash, rigged on the knight-battle SKELETON (chest root, 3/4 head, shield guard, longsword swung about the hand) rather than a slid flat torso. Blade direction is the sword bone's absolute rotate; the arm bone rotates only to travel the hand from raised-overhead to extended-forward, so the whole arm throws the cut. Spacing carries the weight: a slow coil back onto the rear leg (anticipate + a held windup-peak), then an EXPLOSIVE single-frame swing with a large angular delta so it blurs past, a held impact key (hold 3) with a trailing slash crescent, a one-frame overshoot, and a slow settle. The back leg plants while the front leg lunges and the chest leans into the blow.",
  "size": [
    38,
    36
  ],
  "frames": [
    {
      "name": "ready",
      "hold": 2,
      "skeleton": [
        { "name": "back-leg", "shape": "knight_leg", "pivot": "hip", "attach": { "to": "chest", "anchor": "hip_l", "shift": [ -2, 0 ] }, "skew": [ -0.4, 0.0 ] },
        { "name": "front-leg", "shape": "knight_leg", "pivot": "hip", "attach": { "to": "chest", "anchor": "hip_r", "shift": [ 2, 0 ] }, "skew": [ 0.4, 0.0 ] },
        { "name": "chest", "shape": "knight_chest", "pivot": "hips", "at": [ 16, 20 ], "skew": [ -0.1, 0.0 ] },
        { "name": "shield", "shape": "shield", "pivot": "center", "attach": { "to": "chest", "anchor": "hips", "shift": [ -1, -1 ] }, "recolor": { "steel": "cloak", "steel_hi": "cloak_hi", "steel_sh": "cloak_sh" } },
        { "name": "sword-arm", "shape": "knight_arm", "pivot": "shoulder", "attach": { "to": "chest", "anchor": "shoulder_r" }, "rotate": 145 },
        { "name": "sword", "shape": "sword_long", "pivot": "grip", "attach": { "to": "sword-arm", "anchor": "hand" }, "rotate": 33 },
