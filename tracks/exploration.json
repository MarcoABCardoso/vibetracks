{
  "name": "exploration",
  "extends": "../soundtrack.json",
  "_comment": "Calm, spacious overworld music. No full melody — just the first 3 notes of the theme as an occasional callback over evolving pads, so it can loop a long time without fatigue and never feels like 'the song'.",
  "bpm": 100,
  "time_signature": [4, 4],

  "palette": {
    "pluck": { "gain": 0.45, "filter": 3800, "reverb": 0.3 },
    "drums": { "gain": 0.55 }
  },

  "sections": [
    {
      "name": "intro",
      "bars": 4,
      "parts": {
        "pad": { "instrument": "pad", "chords": ["Am", "C", "F", "G"], "chord_beats": 4, "gain": 0.5 }
      }
    },
    {
      "name": "loop",
      "bars": 8,
      "loop": true,
      "parts": {
        "pad":   { "instrument": "pad", "chords": ["Am", "C", "F", "G", "Dm", "Am", "Em", "G"], "chord_beats": 4 },
        "pluck": { "instrument": "pluck", "motif": "main_theme", "slice": [0, 3], "pan": -0.15, "gain": 0.4 },
        "bass":  { "instrument": "bass",
                   "notes": [["A2", 4], ["C2", 4], ["F2", 4], ["G2", 4],
                             ["D2", 4], ["A2", 4], ["E2", 4], ["G2", 4]] },
        "arp":   { "instrument": "arp", "repeat": 8, "pan": 0.3, "gain": 0.28,
                   "notes": [["E5", 1], ["A5", 1], ["C6", 1], ["A5", 1]] },
        "drums": { "instrument": "drums",
                   "drums": { "kick": "x.......", "hat": "..x...x." } }
      }
    }
  ]
}
